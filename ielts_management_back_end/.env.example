# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
APP_NAME=IELTS Management Backend

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ielts_db
MONGODB_TIMEOUT=10000

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRE=30d

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ============================================
# CORS & ALLOWED ORIGINS
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# ============================================
# FILE UPLOAD
# ============================================
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ============================================
# EMAIL SERVICE (SendGrid, Mailgun, etc)
# ============================================
EMAIL_SERVICE_URL=https://api.sendgrid.com/v3/mail/send
EMAIL_SERVICE_KEY=your_email_service_api_key
SENDER_EMAIL=noreply@yourapp.com

# ============================================
# SMS SERVICE (Optional)
# ============================================
SMS_SERVICE_URL=https://api.twilio.com/2010-04-01/Accounts
SMS_SERVICE_KEY=your_sms_service_api_key

# ============================================
# PAYMENT GATEWAY
# ============================================
PAYMENT_API_URL=https://api.payment-provider.com
PAYMENT_API_KEY=your_payment_api_key
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# SESSION & COOKIES
# ============================================
SESSION_SECRET=your_session_secret_key
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# REDIS (For rate limiting, caching, sessions)
# ============================================
# Local: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PREFIX=ielts:
REDIS_ENABLED=true
REDIS_PASSWORD=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PAYMENT_SANDBOX=true
ENABLE_DEBUG_LOGGING=false
